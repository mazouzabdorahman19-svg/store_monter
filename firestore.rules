rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/stores/bella-kraft/admins/$(request.auth.uid));
    }

    // Public catalog document (read by everyone, written by admins only)
    match /stores/bella-kraft {
      allow read: if true;
      allow write: if isAdmin();

      match /admins/{adminId} {
        allow read: if isSignedIn() && request.auth.uid == adminId;
        allow write: if isAdmin();
      }

      match /orders/{orderId} {
        // Allow visitors to place orders (WhatsApp checkout) without an account.
        allow create: if true;
        // Only admins can view/manage orders.
        allow read, update, delete: if isAdmin();
      }

      match /coupons/{couponId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /users/{userId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}

